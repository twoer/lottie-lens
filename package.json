{
  "name": "lottie-lens",
  "version": "1.0.1",
  "description": "Lottie Lens - 本地 Lottie 文件校验、动画预览和资源检查工具",
  "keywords": [
    "lottie",
    "lottie-preview",
    "lottie-validator",
    "lottie-json",
    "animation",
    "asset-inspection",
    "pwa",
    "vue"
  ],
  "author": "twoer <zhangkun_net@hotmail.com>",
  "license": "MIT",
  "homepage": "https://twoer.github.io/lottie-lens/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/twoer/lottie-lens.git"
  },
  "bugs": {
    "url": "https://github.com/twoer/lottie-lens/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore --ignore-pattern \"dist*\"",
    "lint:check": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --ignore-path .gitignore",
    "format": "prettier --write \"src/**/*.{vue,js,ts,json,css,scss,md}\" \"public/**/*.{js,json,webmanifest}\" \"scripts/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.{vue,js,ts,json,css,scss,md}\" \"public/**/*.{js,json,webmanifest}\" \"scripts/**/*.js\"",
    "stylelint": "stylelint \"src/**/*.{css,vue}\" --fix",
    "stylelint:check": "stylelint \"src/**/*.{css,vue}\"",
    "test": "npm run test:unit && npm run test:e2e",
    "test:e2e": "playwright test",
    "test:unit": "vitest run",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@lucide/vue": "^1.21.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lottie-web": "^5.13.0",
    "tailwind-merge": "^3.6.0",
    "vue": "^3.5.24",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^20.19.25",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-typescript": "^11.0.3",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.4.22",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-vue": "^9.33.0",
    "happy-dom": "^20.10.6",
    "postcss": "^8.5.6",
    "postcss-html": "^1.8.0",
    "prettier": "^3.6.2",
    "stylelint": "^16.25.0",
    "stylelint-config-standard": "^39.0.1",
    "stylelint-config-standard-scss": "^16.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "stylelint-scss": "^6.12.1",
    "tailwindcss": "^3.4.18",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  }
}
